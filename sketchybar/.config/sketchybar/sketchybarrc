           --add item protonvpn.popup.changed popup.protonvpn \
           --set protonvpn.popup.changed "${popup_defaults[@]}" icon="Changed" label="-" \
           --add item protonvpn.popup.toggle popup.protonvpn \
           --set protonvpn.popup.toggle "${popup_defaults[@]}" icon="Action" label="-" label.color=0xffff7eb6 click_script="$PLUGIN_DIR/protonvpn_toggle.sh"

sketchybar --set volume \
              popup.align=right \
              popup.height=24 \
              popup.blur_radius=10 \
              popup.background.color=0xdd111111 \
              popup.background.corner_radius=6 \
           --add item volume.popup.output_current popup.volume \
           --set volume.popup.output_current "${popup_defaults[@]}" icon.drawing=off label="Output  -" label.color=0xff9aa4b2 \
           --add item volume.popup.output1 popup.volume \
           --set volume.popup.output1 "${popup_defaults[@]}" icon.drawing=off label="-" \
           --add item volume.popup.output2 popup.volume \
