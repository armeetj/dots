           --set tailscale.popup.state "${popup_defaults[@]}" icon="State" label="-" \
           --add item tailscale.popup.host popup.tailscale \
           --set tailscale.popup.host "${popup_defaults[@]}" icon="Host" label="-" \
           --add item tailscale.popup.ip popup.tailscale \
           --set tailscale.popup.ip "${popup_defaults[@]}" icon="IP" label="-" \
           --add item tailscale.popup.peer1 popup.tailscale \
           --set tailscale.popup.peer1 "${popup_defaults[@]}" icon="Peer" label="-" \
           --add item tailscale.popup.peer2 popup.tailscale \
           --set tailscale.popup.peer2 "${popup_defaults[@]}" icon="Peer" label="-" \
           --add item tailscale.popup.peer3 popup.tailscale \
