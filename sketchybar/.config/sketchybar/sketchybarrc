# https://felixkratz.github.io/SketchyBar/config

export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

PLUGIN_DIR="$CONFIG_DIR/plugins"
export SPACE_BG_INACTIVE=0x00000000
export SPACE_BG_DEFAULT=0x33ffffff

sketchybar --add event yabai_window_mode_change

# ==> Appearance
# https://felixkratz.github.io/SketchyBar/config/bar
sketchybar --bar position=top height=30 blur_radius=10 color=0x88000000 margin=0 padding_left=15 padding_right=15

# https://felixkratz.github.io/SketchyBar/config/items
default=(
  icon.font="Iosevka Nerd Font:Bold:16.0"
  label.font="Iosevka Nerd Font:Bold:16.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

# ==> Window Mode
sketchybar --add item window_mode left \
           --set window_mode \
                drawing=on \
                width=-1 \
                update_freq=1 \
                icon.drawing=off \
                label="□" \
                label.font="Iosevka Nerd Font:Bold:16.0" \
                label.color=0xffffffff \
                label.padding_left=0 \
                label.padding_right=5 \
                label.y_offset=0 \
                background.drawing=off \
                padding_left=0 \
                padding_right=0 \
                script="$PLUGIN_DIR/window_mode.sh" \
           --subscribe window_mode yabai_window_mode_change front_app_switched

# ==> Spaces
spaces_json=$(yabai -m query --spaces)

for sid in $(jq '.[].index' <<<"$spaces_json"); do
    label=$(jq -r ".[] | select(.index == $sid) | if .label == \"\" then (.index|tostring) else .label end" <<<"$spaces_json")

    space=(
      space="$sid"
      icon.drawing=off
      label="$label"
      padding_left=0
      padding_right=0
      label.padding_left=4
      label.padding_right=4
      associated_display=active
      background.color="$SPACE_BG_INACTIVE"
      background.corner_radius=0
      background.height=20
      background.padding_left=0
      background.padding_right=0
      background.drawing=off
      script="$PLUGIN_DIR/space.sh $sid"
    )

    sketchybar --add space space."$sid" left \
               --set space."$sid" "${space[@]}" \
               --subscribe space."$sid" mouse.clicked
done

# ==> Left Items
sketchybar --add item front_app left \
           --set front_app icon.drawing=off script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

# ==> Right Items
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar
# https://felixkratz.github.io/SketchyBar/config/events

sketchybar --add item clock right \
           --set clock update_freq=1 icon.drawing=off script="$PLUGIN_DIR/clock.sh" click_script="$PLUGIN_DIR/clock_click.sh" \
           --subscribe clock mouse.exited.global \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" click_script="$PLUGIN_DIR/volume_click.sh" \
           --subscribe volume volume_change mouse.exited.global \
           --add item battery right \
           --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change \
           --add item protonvpn right \
           --set protonvpn update_freq=5 icon.drawing=off label="VPN" script="$PLUGIN_DIR/protonvpn.sh" click_script="$PLUGIN_DIR/protonvpn_menu.sh" \
           --subscribe protonvpn mouse.exited.global \
           --add item tailscale right \
           --set tailscale update_freq=5 icon.drawing=off label="TS" script="$PLUGIN_DIR/tailscale.sh" click_script="$PLUGIN_DIR/tailscale_click.sh" \
           --subscribe tailscale mouse.exited.global

