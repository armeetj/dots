           --add item volume.popup.output5 popup.volume \
           --set volume.popup.output5 "${popup_defaults[@]}" icon.drawing=off label="-" \
           --add item volume.popup.input_current popup.volume \
           --set volume.popup.input_current "${popup_defaults[@]}" icon.drawing=off label="Input   -" label.color=0xff9aa4b2 \
           --add item volume.popup.input1 popup.volume \
